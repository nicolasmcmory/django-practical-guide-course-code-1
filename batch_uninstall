#!/bin/bash

# List of packages to uninstall (not needed for Django development)
UNNEEDED_PACKAGES=(
 <package_name_1>...  # Replace with actual package names
)

for pkg in "${UNNEEDED_PACKAGES[@]}"; do
  if pip show "$pkg" > /dev/null 2>&1; then
    pip uninstall -y "$pkg"
  else
    echo "Package '$pkg' not installed, skipping."
  fi
done